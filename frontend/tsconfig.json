{
    "compilerOptions": {
        "target": "ES2020",
        "module": "ESNext",
        "lib": [
            "dom",
            "dom.iterable",
            "es2020"
        ],
        "allowJs": false,
        "skipLibCheck": true,
        "strict": true,
        "esModuleInterop": true,
        "moduleResolution": "node",
        "resolveJsonModule": true,
        "isolatedModules": true,
        "jsx": "react-jsx",
        "types": [
            "node",
            "jest"
        ],
        "noEmit": true,
        "forceConsistentCasingInFileNames": true
    },
    "include": [
        "src"
    ]
}